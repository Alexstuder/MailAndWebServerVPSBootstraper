# ==============================================================================
# VPS STACK UMGUNGSVARIABLEN (Template)
# 
# Kopiere diese Datei zu ".env" und fülle die echten Werte ein. 
# Verschlüssele sie danach mit GPG zu ".env.gpg" für das GitHub Repository.
# ==============================================================================

# ─────────────────────────────────────────────────────────────
# DOMAINS (Aktuelle Testphase: alexstuder.cloud)
# Bei einem Server/Domain-Wechsel (z.B. auf alexstuder.ch) 
# werden die Domains primär hier zentral angepasst.
# ─────────────────────────────────────────────────────────────
MAIL_DOMAIN=mail.alexstuder.cloud
API_EXTERNAL_URL=https://api.alexstuder.cloud
# WEB_DOMAIN=www.alexstuder.cloud       # (Optional, zur Dokumentation)
# PORTAINER_DOMAIN=portainer.alexstuder.cloud # (Optional, zur Dokumentation)

# ─────────────────────────────────────────────────────────────
# CLOUDFLARE (Tunnel & Auto-DNS)
# Generiert beim Erstellen des Tunnels bzw. im DNS Dashboard.
# ─────────────────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=dein_cloudflare_tunnel_token_hier_einfuegen
CF_API_TOKEN=dein_cloudflare_api_token_fuer_dns_updates
CF_ZONE_ID=deine_cloudflare_zone_id

# ─────────────────────────────────────────────────────────────
# SUPABASE CORE (Datenbank & Auth)
# WICHTIG: Das JWT_SECRET muss zwingend mindestens 32 Zeichen lang sein!
# WICHTIG: POSTGRES_PASSWORD sollte sicher und komplex generiert werden.
# ─────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=dein_super_sicheres_postgres_passwort_min_14_char
JWT_SECRET=dein_mindestens_32_zeichen_langes_kryptographisches_jwt_secret

# ─────────────────────────────────────────────────────────────
# BACKUPS (Cloudflare R2 API)
# Diese Werte erhältst du im Cloudflare Dashboard unter "R2" -> "API Tokens"
# ─────────────────────────────────────────────────────────────
CF_R2_ACCESS_KEY=dein_r2_access_key
CF_R2_SECRET_KEY=dein_r2_secret_key
CF_R2_ENDPOINT=https://deine_account_id_hier.r2.cloudflarestorage.com
CF_R2_BUCKET=dein_backup_bucket_name

# ─────────────────────────────────────────────────────────────
# INIT & MANAGEMENT PASSWÖRTER
# ─────────────────────────────────────────────────────────────
PORTAINER_ADMIN_PASSWORD=dein_starkes_admin_passwort_fuer_portainer

# ─────────────────────────────────────────────────────────────
# CLAUDE CODE (KI-Assistent im Terminal)
# API Key erstellen unter: https://console.anthropic.com → API Keys
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-dein_anthropic_api_key_hier

# ==============================================================================
# HINWEIS: 
# Das Feld "BACKUP_MAIL_GPG_PASSWORD" wird vollautomatisch von 'bootstrap.sh' 
# aus deinem Bitwarden in die de-verschlüsselte .env-Datei injiziert.
# ==============================================================================
